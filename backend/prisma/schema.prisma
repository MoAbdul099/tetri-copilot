model ComplianceCalendarItem {
  id               String       @id @default(uuid()) @db.Uuid
  countryProfileId String       @map("country_profile_id") @db.Uuid
  title            String       @db.VarChar(255)
  description      String?      @db.Text
  reminderType     ReminderType @default(compliance) @map("reminder_type")
  recurrenceRule   String?      @map("recurrence_rule") @db.Text
  defaultDueMonth  Int?         @map("default_due_month")
  defaultDueDay    Int?         @map("default_due_day")
  leadDays         Int          @default(7) @map("lead_days")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  countryProfile CountryProfile @relation(fields: [countryProfileId], references: [id], onDelete: Cascade)
  reminders      Reminder[]

  @@map("compliance_calendar_items")
}

model Reminder {
  id                       String         @id @default(uuid()) @db.Uuid
  workspaceId              String         @map("workspace_id") @db.Uuid
  countryProfileId         String?        @map("country_profile_id") @db.Uuid
  complianceCalendarItemId String?        @map("compliance_calendar_item_id") @db.Uuid
  relatedInvoiceId         String?        @map("related_invoice_id") @db.Uuid
  title                    String         @db.VarChar(255)
  description              String?        @db.Text
  reminderType             ReminderType   @default(custom) @map("reminder_type")
  dueDate                  DateTime       @map("due_date") @db.Date
  remindAt                 DateTime?      @map("remind_at") @db.Timestamptz(6)
  status                   ReminderStatus @default(pending)
  createdByUserId          String?        @map("created_by_user_id") @db.Uuid
  assignedToUserId         String?        @map("assigned_to_user_id") @db.Uuid
  createdAt                DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  countryProfile         CountryProfile?         @relation(fields: [countryProfileId], references: [id])
  complianceCalendarItem ComplianceCalendarItem? @relation(fields: [complianceCalendarItemId], references: [id], onDelete: SetNull)
  relatedInvoice         Invoice?                @relation(fields: [relatedInvoiceId], references: [id], onDelete: Cascade)
  createdByUser          User?                   @relation("ReminderCreatedBy", fields: [createdByUserId], references: [id])
  assignedToUser         User?                   @relation("ReminderAssignedTo", fields: [assignedToUserId], references: [id])

  logs ReminderLog[]

  @@index([workspaceId])
  @@index([dueDate])
  @@index([status])
  @@index([reminderType])
  @@map("reminders")
}

model ReminderLog {
  id                String              @id @default(uuid()) @db.Uuid
  reminderId        String              @map("reminder_id") @db.Uuid
  channel           NotificationChannel
  status            NotificationStatus  @default(pending)
  sentTo            String?             @map("sent_to") @db.VarChar(255)
  providerMessageId String?             @map("provider_message_id") @db.VarChar(255)
  errorMessage      String?             @map("error_message") @db.Text
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@map("reminder_logs")
}

// =========================================================
// NOTIFICATIONS
// =========================================================

model Notification {
  id                String              @id @default(uuid()) @db.Uuid
  workspaceId       String              @map("workspace_id") @db.Uuid
  userId            String?             @map("user_id") @db.Uuid
  title             String              @db.VarChar(255)
  message           String?             @db.Text
  channel           NotificationChannel @default(dashboard)
  status            NotificationStatus  @default(pending)
  relatedEntityType String?             @map("related_entity_type") @db.VarChar(100)
  relatedEntityId   String?             @map("related_entity_id") @db.Uuid
  readAt            DateTime?           @map("read_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@map("notifications")
}

// =========================================================
// AI ASSISTANT & AI USAGE
// =========================================================

model AiConversation {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String?  @db.VarChar(255)
  languageId  String?  @map("language_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  language  Language? @relation(fields: [languageId], references: [id])

  messages AiMessage[]

  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   @db.VarChar(50)
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model AiUsageLog {
  id               String          @id @default(uuid()) @db.Uuid
  workspaceId      String          @map("workspace_id") @db.Uuid
  userId           String?         @map("user_id") @db.Uuid
  requestType      AiRequestType   @map("request_type")
  status           AiRequestStatus @default(success)
  provider         String          @default("openai") @db.VarChar(50)
  model            String?         @db.VarChar(100)
  inputTokens      Int?            @default(0) @map("input_tokens")
  outputTokens     Int?            @default(0) @map("output_tokens")
  totalTokens      Int?            @default(0) @map("total_tokens")
  estimatedCostUsd Decimal?        @default(0) @map("estimated_cost_usd") @db.Decimal(12, 6)
  requestSummary   String?         @map("request_summary") @db.Text
  errorMessage     String?         @map("error_message") @db.Text
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

// =========================================================
// AI DOCUMENT GENERATION
// =========================================================

model DocumentTemplate {
  id              String       @id @default(uuid()) @db.Uuid
  workspaceId     String?      @map("workspace_id") @db.Uuid
  countryProfileId String?     @map("country_profile_id") @db.Uuid
  documentType    DocumentType @map("document_type")
  name            String       @db.VarChar(255)
  description     String?      @db.Text
  templateContent String?      @map("template_content") @db.Text
  languageId      String?      @map("language_id") @db.Uuid
  isSystemDefault Boolean      @default(false) @map("is_system_default")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace      Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  countryProfile CountryProfile? @relation(fields: [countryProfileId], references: [id], onDelete: SetNull)
  language       Language?       @relation(fields: [languageId], references: [id])

  generatedDocuments GeneratedDocument[]

  @@map("document_templates")
}

model GeneratedDocument {
  id                String         @id @default(uuid()) @db.Uuid
  workspaceId       String         @map("workspace_id") @db.Uuid
  templateId        String?        @map("template_id") @db.Uuid
  documentType      DocumentType   @map("document_type")
  status            DocumentStatus @default(draft)
  title             String         @db.VarChar(255)
  content           String?        @db.Text
  languageId        String?        @map("language_id") @db.Uuid
  pdfFileId         String?        @map("pdf_file_id") @db.Uuid
  generatedByUserId String?        @map("generated_by_user_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace       Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template        DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  language        Language?         @relation(fields: [languageId], references: [id])
  pdfFile         File?             @relation(fields: [pdfFileId], references: [id], onDelete: SetNull)
  generatedByUser User?             @relation(fields: [generatedByUserId], references: [id])

  @@map("generated_documents")
}

// =========================================================
// ADMIN, ACTIVITY & AUDIT LOGS
// =========================================================

model ActivityLog {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String?  @map("workspace_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  action          String   @db.VarChar(150)
  eventId         String?  @map("event_id") @db.Uuid
  eventVersion    String?  @map("event_version") @db.VarChar(20)
  userName        String?  @map("user_name") @db.VarChar(200)
  module          String?  @db.VarChar(100)
  category        String?  @db.VarChar(100)
  entityType      String?  @map("entity_type") @db.VarChar(100)
  entityId        String?  @map("entity_id") @db.Uuid
  referenceNumber String?  @map("reference_number") @db.VarChar(100)
  description     String?  @db.Text
  metadata        Json?
  ipAddress       String?  @map("ip_address") @db.VarChar(100)
  userAgent       String?  @map("user_agent") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@index([module])
  @@index([category])
  @@index([referenceNumber])
  @@index([entityType])
  @@index([entityId])
  @@map("activity_logs")
}

model AuditLog {
  id                   String   @id @default(uuid()) @db.Uuid
  workspaceId          String?  @map("workspace_id") @db.Uuid
  userId               String?  @map("user_id") @db.Uuid
  userName             String?  @map("user_name") @db.VarChar(200)
  eventId              String?  @map("event_id") @db.Uuid
  correlationId        String?  @map("correlation_id") @db.Uuid
  action               String   @db.VarChar(150)
  entityType           String?  @map("entity_type") @db.VarChar(100)
  entityId             String?  @map("entity_id") @db.Uuid
  fieldChangesJson     Json?    @map("field_changes_json")
  beforeSnapshotJson   Json?    @map("before_snapshot_json")
  afterSnapshotJson    Json?    @map("after_snapshot_json")
  recordHash           String?  @map("record_hash") @db.VarChar(64)
  previousRecordHash   String?  @map("previous_record_hash") @db.VarChar(64)
  chainHash            String?  @map("chain_hash") @db.VarChar(64)
  isLegalHold          Boolean  @default(false) @map("is_legal_hold")
  ipAddress            String?  @map("ip_address") @db.VarChar(100)
  userAgent            String?  @map("user_agent") @db.Text
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([correlationId])
  @@index([recordHash])
  @@index([chainHash])
  @@index([createdAt])
  @@map("audit_logs")
}

// =========================================================
// SECURITY & MONITORING
// =========================================================

model SecurityEvent {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  eventId     String?  @map("event_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(150)
  category    String   @db.VarChar(100)
  riskScore   Int      @default(0) @map("risk_score")
  severity    String   @db.VarChar(20)
  entityType  String?  @map("entity_type") @db.VarChar(100)
  entityId    String?  @map("entity_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  userName    String?  @map("user_name") @db.VarChar(200)
  description String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([category])
  @@index([severity])
  @@index([eventType])
  @@index([createdAt])
  @@map("security_events")
}

model SecurityAlert {
  id                String    @id @default(uuid()) @db.Uuid
  workspaceId       String    @map("workspace_id") @db.Uuid
  alertType         String    @map("alert_type") @db.VarChar(150)
  category          String    @db.VarChar(100)
  severity          String    @db.VarChar(20)
  riskScore         Int       @default(0) @map("risk_score")
  status            String    @default("new") @db.VarChar(30)
  entityType        String?   @map("entity_type") @db.VarChar(100)
  entityId          String?   @map("entity_id") @db.Uuid
  userId            String?   @map("user_id") @db.Uuid
  userName          String?   @map("user_name") @db.VarChar(200)
  description       String?   @db.Text
  recommendedAction String?   @map("recommended_action") @db.Text
  assignedUserId    String?   @map("assigned_user_id") @db.Uuid
  notes             String?   @db.Text
  resolvedAt        DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
  @@index([severity])
  @@index([userId])
  @@index([createdAt])
  @@map("security_alerts")
}

model SecurityRule {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  ruleName    String   @map("rule_name") @db.VarChar(150)
  category    String   @db.VarChar(100)
  eventType   String   @map("event_type") @db.VarChar(150)
  threshold   Int      @default(1)
  windowMins  Int      @default(60) @map("window_mins")
  riskScore   Int      @default(10) @map("risk_score")
  severity    String   @db.VarChar(20)
  description String?  @db.Text
  recommendedAction String? @map("recommended_action") @db.Text
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("security_rules")
}

// =========================================================
// PAYMENTS & ALLOCATIONS
// =========================================================

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  workspaceId       String        @map("workspace_id") @db.Uuid
  customerId        String        @map("customer_id") @db.Uuid
  paymentNumber     String        @map("payment_number") @db.VarChar(100)
  status            PaymentStatus @default(draft)
  paymentDate       DateTime      @map("payment_date") @db.Date
  amount            Decimal       @db.Decimal(14, 2)
  currencyCode      String        @default("USD") @map("currency_code") @db.VarChar(10)
  paymentMethod     PaymentMethod @default(bank_transfer) @map("payment_method")
  referenceNumber   String?       @map("reference_number") @db.VarChar(100)
  bankReference     String?       @map("bank_reference") @db.VarChar(100)
  chequeNumber      String?       @map("cheque_number") @db.VarChar(100)
  depositDate       DateTime?     @map("deposit_date") @db.Date
  valueDate         DateTime?     @map("value_date") @db.Date
  allocatedAmount   Decimal       @default(0) @map("allocated_amount") @db.Decimal(14, 2)
  unallocatedAmount Decimal       @default(0) @map("unallocated_amount") @db.Decimal(14, 2)
  isAdvance         Boolean       @default(false) @map("is_advance")
  notes             String?       @db.Text
  reversalReason    String?       @map("reversal_reason") @db.Text
  reversedAt        DateTime?     @map("reversed_at") @db.Timestamptz(6)
  reversedById      String?       @map("reversed_by_id") @db.Uuid
  voidedAt          DateTime?     @map("voided_at") @db.Timestamptz(6)
  postedAt          DateTime?     @map("posted_at") @db.Timestamptz(6)
  createdByUserId   String?       @map("created_by_user_id") @db.Uuid
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer      Customer  @relation(fields: [customerId], references: [id])
  createdByUser User?     @relation("PaymentCreatedBy", fields: [createdByUserId], references: [id])
  reversedByUser User?    @relation("PaymentReversedBy", fields: [reversedById], references: [id])

  allocations   PaymentAllocation[]
  statusHistory PaymentStatusHistory[]
  attachments   PaymentAttachment[]
  credits       CustomerCredit[]

  @@unique([workspaceId, paymentNumber])
  @@index([workspaceId])
  @@index([customerId])
  @@index([status])
  @@index([paymentDate])
  @@map("payments")
}

model PaymentAllocation {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  paymentId       String   @map("payment_id") @db.Uuid
  invoiceId       String   @map("invoice_id") @db.Uuid
  allocatedAmount Decimal  @map("allocated_amount") @db.Decimal(14, 2)
  notes           String?  @db.Text
  allocatedById   String?  @map("allocated_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([paymentId])
  @@index([invoiceId])
  @@map("payment_allocations")
}

model PaymentStatusHistory {
  id          String         @id @default(uuid()) @db.Uuid
  paymentId   String         @map("payment_id") @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  fromStatus  PaymentStatus? @map("from_status")
  toStatus    PaymentStatus  @map("to_status")
  changedById String?        @map("changed_by_id") @db.Uuid
  reason      String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("payment_status_history")
}

model PaymentAttachment {
  id             String   @id @default(uuid()) @db.Uuid
  paymentId      String   @map("payment_id") @db.Uuid
  workspaceId    String   @map("workspace_id") @db.Uuid
  fileName       String   @map("file_name") @db.VarChar(255)
  storedFileName String   @map("stored_file_name") @db.VarChar(255)
  mimeType       String   @map("mime_type") @db.VarChar(100)
  fileSize       BigInt   @map("file_size")
  storagePath    String   @map("storage_path") @db.Text
  description    String?  @db.Text
  uploadedById   String?  @map("uploaded_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([workspaceId])
  @@map("payment_attachments")
}

model CustomerCredit {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  paymentId       String?  @map("payment_id") @db.Uuid
  currencyCode    String   @default("USD") @map("currency_code") @db.VarChar(10)
  originalAmount  Decimal  @map("original_amount") @db.Decimal(14, 2)
  usedAmount      Decimal  @default(0) @map("used_amount") @db.Decimal(14, 2)
  remainingAmount Decimal  @map("remaining_amount") @db.Decimal(14, 2)
  notes           String?  @db.Text
  createdById     String?  @map("created_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer     Customer  @relation(fields: [customerId], references: [id])
  sourcePayment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  transactions CustomerCreditTransaction[]

  @@index([workspaceId])
  @@index([customerId])
  @@map("customer_credits")
}

model CustomerCreditTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  creditId     String   @map("credit_id") @db.Uuid
  invoiceId    String?  @map("invoice_id") @db.Uuid
  amount       Decimal  @db.Decimal(14, 2)
  type         String   @db.VarChar(50)
  notes        String?  @db.Text
  createdById  String?  @map("created_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  credit CustomerCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([creditId])
  @@map("customer_credit_transactions")
}

// =========================================================
// RECEIVABLES — COLLECTIONS & STATEMENTS
// =========================================================

model CollectionActivity {
  id               String                 @id @default(uuid()) @db.Uuid
  workspaceId      String                 @map("workspace_id") @db.Uuid
  customerId       String                 @map("customer_id") @db.Uuid
  invoiceId        String?                @map("invoice_id") @db.Uuid
  activityType     CollectionActivityType @default(phone_call) @map("activity_type")
  status           CollectionStatus       @default(pending)
  activityDate     DateTime               @map("activity_date") @db.Date
  notes            String?                @db.Text
  outcome          String?                @db.Text
  nextFollowUpDate DateTime?              @map("next_follow_up_date") @db.Date
  assignedToUserId String?                @map("assigned_to_user_id") @db.Uuid
  createdByUserId  String?                @map("created_by_user_id") @db.Uuid
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer      Customer  @relation(fields: [customerId], references: [id])
  assignedUser  User?     @relation("CollectionAssigned", fields: [assignedToUserId], references: [id])
  createdByUser User?     @relation("CollectionCreated", fields: [createdByUserId], references: [id])

  @@index([workspaceId])
  @@index([customerId])
