// =========================================================
// Tetri Copilot Prisma Schema
// AI-First Lightweight SME Operating Assistant
// Version: 2.0 MVP
// Database: PostgreSQL on Ubuntu VPS
// Backend: Express.js REST API on Ubuntu VPS
// Frontend: React + Vite deployed to Cloudflare Pages
// ORM: Prisma Client
// =========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// ENUMS
// =========================================================

enum UserStatus {
  active
  inactive
  invited
  suspended
}

enum SystemRole {
  admin
  owner
  user
  viewer
}

enum SubscriptionPlanCode {
  free
  starter
  professional
  business
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  expired
}

enum InvoiceStatus {
  draft
  issued
  sent
  partially_paid
  paid
  overdue
  cancelled
  void
}

enum PaymentStatus {
  draft
  posted
  allocated
  partially_allocated
  unallocated
  reversed
  voided
}

enum PaymentMethod {
  cash
  bank_transfer
  credit_card
  debit_card
  cheque
  mobile_wallet
  pos
  online_transfer
  other
}

enum ExpenseStatus {
  draft
  submitted
  pending_approval
  approved
  rejected
  returned
  cancelled
  closed
}

enum ExpenseType {
  company
  employee
  petty_cash
}

enum ReminderType {
  tax
  invoice_due
  payment
  compliance
  custom
}

enum ReminderStatus {
  pending
  sent
  completed
  cancelled
  overdue
}

enum NotificationChannel {
  dashboard
  email
}

enum NotificationStatus {
  pending
  sent
  failed
  read
}

enum DocumentType {
  quotation
  nda
  freelance_agreement
  offer_letter
  operational_letter
  other
}

enum DocumentStatus {
  draft
  generated
  approved
  archived
}

enum AiRequestType {
  chat
  document_generation
  expense_categorization
  compliance_guidance
  invoice_guidance
}

enum AiRequestStatus {
  success
  failed
  blocked_limit
  blocked_permission
}

enum BillingEventType {
  checkout_created
  subscription_created
  subscription_updated
  subscription_cancelled
  payment_succeeded
  payment_failed
}

enum CustomerType {
  individual
  company
  government
  ngo
  other
}

enum CustomerStatus {
  active
  inactive
  suspended
  archived
}

enum CollectionActivityType {
  phone_call
  email
  meeting
  reminder
  escalation
  site_visit
  other
}

enum CollectionStatus {
  pending
  contacted
  awaiting_response
  promise_to_pay
  partially_settled
  escalated
  closed
}

enum PromiseStatus {
  pending
  fulfilled
  broken
  cancelled
}

// =========================================================
// LOCALIZATION
// =========================================================

model Language {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(10)
  name       String   @db.VarChar(100)
  nativeName String?  @map("native_name") @db.VarChar(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  users                   User[]
  defaultCountryProfiles  CountryProfile[]       @relation("DefaultCountryLanguage")
  countryProfileLanguages CountryProfileLanguage[]
  workspaces              Workspace[]
  invoices                Invoice[]
  aiConversations         AiConversation[]
  documentTemplates       DocumentTemplate[]
  generatedDocuments      GeneratedDocument[]

  @@map("languages")
}

model Currency {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(3)
  name      String   @db.VarChar(100)
  symbol    String?  @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  defaultCountryProfiles CountryProfile[] @relation("DefaultCountryCurrency")
  workspaces             Workspace[]
  invoices               Invoice[]
  expenses               Expense[]

  @@map("currencies")
}

model CountryProfile {
  id                String   @id @default(uuid()) @db.Uuid
  countryCode       String   @unique @map("country_code") @db.VarChar(5)
  countryName       String   @map("country_name") @db.VarChar(150)
  defaultCurrencyId String?  @map("default_currency_id") @db.Uuid
  defaultLanguageId String?  @map("default_language_id") @db.Uuid
  dateFormat        String?  @default("YYYY-MM-DD") @map("date_format") @db.VarChar(50)
  timezone          String?  @db.VarChar(100)
  taxLabel          String?  @map("tax_label") @db.VarChar(50)
  taxNumberLabel    String?  @map("tax_number_label") @db.VarChar(100)
  defaultTaxRate    Decimal? @default(0) @map("default_tax_rate") @db.Decimal(10, 4)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  defaultCurrency Currency? @relation("DefaultCountryCurrency", fields: [defaultCurrencyId], references: [id])
  defaultLanguage Language? @relation("DefaultCountryLanguage", fields: [defaultLanguageId], references: [id])

  languages               CountryProfileLanguage[]
  workspaces              Workspace[]
  companyJurisdictions    Company[]              @relation("CompanyJurisdiction")
  complianceCalendarItems ComplianceCalendarItem[]
  reminders               Reminder[]
  documentTemplates       DocumentTemplate[]

  @@map("country_profiles")
}

model CountryProfileLanguage {
  id               String  @id @default(uuid()) @db.Uuid
  countryProfileId String  @map("country_profile_id") @db.Uuid
  languageId       String  @map("language_id") @db.Uuid
  isDefault        Boolean @default(false) @map("is_default")

  countryProfile CountryProfile @relation(fields: [countryProfileId], references: [id], onDelete: Cascade)
  language       Language       @relation(fields: [languageId], references: [id])

  @@unique([countryProfileId, languageId])
  @@map("country_profile_languages")
}

// =========================================================
// USERS, WORKSPACES & MEMBERSHIP
// =========================================================

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  clerkUserId         String?    @unique @map("clerk_user_id") @db.VarChar(255)
  email               String     @unique @db.VarChar(255)
  fullName            String?    @map("full_name") @db.VarChar(255)
  phone               String?    @db.VarChar(50)
  preferredLanguageId String?    @map("preferred_language_id") @db.Uuid
  status              UserStatus @default(active)
  isPlatformAdmin     Boolean    @default(false) @map("is_platform_admin")
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  preferredLanguage Language? @relation(fields: [preferredLanguageId], references: [id])

  ownedWorkspaces           Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships      WorkspaceMember[]  @relation("WorkspaceMemberUser")
  invitedWorkspaceMembers   WorkspaceMember[]  @relation("WorkspaceMemberInvitedBy")
  sentInvitations           Invitation[]       @relation("InvitedBy")
  uploadedFiles             File[]             @relation("FileUploadedBy")
  deletedFiles              File[]             @relation("FileDeletedBy")
  fileLinksCreated          FileLink[]         @relation("FileLinkCreatedBy")
  fileActivities            FileActivityLog[]  @relation("FileActivityLogUser")
  createdCustomers          Customer[]
  createdInvoices           Invoice[]
  invoicePayments           InvoicePayment[]
  createdPayments           Payment[]        @relation("PaymentCreatedBy")
  reversedPayments          Payment[]        @relation("PaymentReversedBy")
  recurringInvoices         RecurringInvoice[]
  createdExpenses           Expense[]
  createdReminders          Reminder[]         @relation("ReminderCreatedBy")
  assignedReminders         Reminder[]         @relation("ReminderAssignedTo")
  notifications             Notification[]
  aiConversations           AiConversation[]
  aiUsageLogs               AiUsageLog[]
  generatedDocuments        GeneratedDocument[]
  activityLogs              ActivityLog[]
  auditLogs                 AuditLog[]
  assignedCollections           CollectionActivity[]   @relation("CollectionAssigned")
  createdCollections            CollectionActivity[]   @relation("CollectionCreated")
  createdSuppliers              Supplier[]             @relation("SupplierCreatedBy")
  approvalRulesAsApprover       ApprovalRule[]         @relation("ApprovalRuleApprover")
  approvalRulesCreated          ApprovalRule[]         @relation("ApprovalRuleCreatedBy")
  submittedApprovalWorkflows    ApprovalWorkflow[]     @relation("WorkflowSubmittedBy")
  approvalAssignments           ApprovalAssignment[]   @relation("AssignmentAssignedTo")
  approvalDecisions             ApprovalAssignment[]   @relation("AssignmentDecidedBy")
  approvalComments              ApprovalComment[]      @relation("ApprovalCommentUser")
  delegationsGiven              ApprovalDelegation[]   @relation("DelegationDelegator")
  delegationsReceived           ApprovalDelegation[]   @relation("DelegationDelegate")
  reimbursementRequestsMade     ReimbursementRequest[] @relation("ReimbursementRequestedBy")
  reimbursementsApproved        ReimbursementRequest[] @relation("ReimbursementApprovedBy")
  reimbursementsRejected        ReimbursementRequest[] @relation("ReimbursementRejectedBy")
  reimbursementPaymentsRecorded ReimbursementPayment[] @relation("ReimbursementPaymentRecordedBy")
  approvalAuditLogs             ApprovalAuditLog[]     @relation("ApprovalAuditLogUser")
  budgetsCreated                Budget[]               @relation("BudgetCreatedBy")
  recurringExpensesCreated      RecurringExpense[]     @relation("RecurringExpenseCreatedBy")
  ownedComplianceTemplates      ComplianceTemplate[]   @relation("ComplianceTemplateOwner")
  backupComplianceTemplates     ComplianceTemplate[]   @relation("ComplianceTemplateBackupOwner")
  ownedComplianceOccurrences    ComplianceOccurrence[] @relation("ComplianceOccurrenceOwner")
  backupComplianceOccurrences   ComplianceOccurrence[] @relation("ComplianceOccurrenceBackupOwner")
  complianceSubmissions         ComplianceSubmission[] @relation("ComplianceSubmittedBy")
  complianceComments            ComplianceComment[]    @relation("ComplianceCommentAuthor")
  complianceActivityLogs        ComplianceActivityLog[] @relation("ComplianceActivityActor")
  notificationItems             NotificationItem[]      @relation("NotificationItemRecipient")
  notificationPreferences       NotificationPreference[] @relation("UserNotificationPreference")
  complianceSavedReports        ComplianceSavedReport[]  @relation("SavedReportUser")
  notificationAuditLogs         NotificationAuditLog[]
  emailTemplatesCreated         EmailTemplate[]          @relation("EmailTemplateCreatedBy")
  emailTemplatesUpdated         EmailTemplate[]          @relation("EmailTemplateUpdatedBy")
  emailTemplateVersionsSaved    EmailTemplateVersion[]   @relation("EmailTemplateVersionSavedBy")
  announcementsCreated          Announcement[]           @relation("AnnouncementCreatedBy")
  announcementReads             AnnouncementRead[]
  dashboardPreferences          DashboardPreference[]
  savedReports                  SavedReport[]
  scheduledReports              ScheduledReport[]
  reportExportJobs              ReportExportJob[]
  reportExecutionLogs           ReportExecutionLog[]

  @@index([clerkUserId])
  @@index([email])
  @@map("users")
}

model Workspace {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(255)
  ownerUserId       String   @map("owner_user_id") @db.Uuid
  countryProfileId  String?  @map("country_profile_id") @db.Uuid
  defaultCurrencyId String?  @map("default_currency_id") @db.Uuid
  defaultLanguageId String?  @map("default_language_id") @db.Uuid
  status            String   @default("active") @db.VarChar(50)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner           User            @relation("WorkspaceOwner", fields: [ownerUserId], references: [id])
  countryProfile  CountryProfile? @relation(fields: [countryProfileId], references: [id])
  defaultCurrency Currency?       @relation(fields: [defaultCurrencyId], references: [id])
  defaultLanguage Language?       @relation(fields: [defaultLanguageId], references: [id])

  members           WorkspaceMember[]
  invitations       Invitation[]
  company           Company?
  companySettings   CompanySettings?
  subscription      Subscription?
  billingEvents     BillingEvent[]
  files             File[]
  customers         Customer[]
  customerContacts  CustomerContact[]
  customerNotes     CustomerNote[]
  customerAttachments CustomerAttachment[]
  customerTags      CustomerTag[]
  customerTagAssignments CustomerTagAssignment[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  payments          Payment[]
  customerCredits   CustomerCredit[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  reminders         Reminder[]
  notifications     Notification[]
  aiConversations   AiConversation[]
  aiUsageLogs       AiUsageLog[]
  documentTemplates DocumentTemplate[]
  generatedDocuments GeneratedDocument[]
  activityLogs        ActivityLog[]
  auditLogs           AuditLog[]
  collectionActivities CollectionActivity[]
  paymentPromises      PaymentPromise[]
  statementRuns        StatementRun[]
  suppliers            Supplier[]
  approvalRules        ApprovalRule[]
  approvalWorkflows    ApprovalWorkflow[]
  approvalDelegations  ApprovalDelegation[]
  reimbursementRequests ReimbursementRequest[]
  reimbursementPayments ReimbursementPayment[]
  approvalAuditLogs    ApprovalAuditLog[]
  budgets              Budget[]
  recurringExpenses    RecurringExpense[]
  recurringExpenseRuns RecurringExpenseRun[]
  expenseInsights      ExpenseInsight[]
  expenseAnomalies     ExpenseAnomaly[]
  fileLinks            FileLink[]
  fileActivityLogs     FileActivityLog[]
  complianceTemplates  ComplianceTemplate[]
  complianceOccurrences ComplianceOccurrence[]
  complianceSubmissions ComplianceSubmission[]
  complianceComments   ComplianceComment[]
  complianceActivityLogs ComplianceActivityLog[]
  complianceCategories    ComplianceCategory[]
  notificationItems            NotificationItem[]
  notificationProfiles         NotificationProfile[]
  notificationPreferences      NotificationPreference[]
  escalationProfiles           EscalationProfile[]
  escalationInstances          EscalationInstance[]
  complianceSavedReports       ComplianceSavedReport[]
  workspaceNotificationSettings WorkspaceNotificationSettings?
  notificationAuditLogs        NotificationAuditLog[]
  emailDeliveryLogs            EmailDeliveryLog[]
  workspaceReminderRules       WorkspaceReminderRule[]
  workspaceEscalationRules     WorkspaceEscalationRule[]
  announcements                Announcement[]
  dashboardPreferences         DashboardPreference[]
  savedReports                 SavedReport[]
  scheduledReports             ScheduledReport[]
  reportExportJobs             ReportExportJob[]
  reportExecutionLogs          ReportExecutionLog[]
  analyticsSnapshots           AnalyticsSnapshot[]
  forecasts                    Forecast[]
  businessHealthScores         BusinessHealthScore[]
  aiInsights                   AiInsight[]
  riskAlerts                   RiskAlert[]
  securityEvents               SecurityEvent[]
  securityAlerts               SecurityAlert[]
  securityRules                SecurityRule[]

  @@map("workspaces")
}

model WorkspaceMember {
  id              String     @id @default(uuid()) @db.Uuid
  workspaceId     String     @map("workspace_id") @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  role            SystemRole @default(user)
  status          UserStatus @default(active)
  invitedByUserId String?    @map("invited_by_user_id") @db.Uuid
  joinedAt        DateTime?  @map("joined_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User      @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser User?     @relation("WorkspaceMemberInvitedBy", fields: [invitedByUserId], references: [id])

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
  @@map("workspace_members")
}

model Invitation {
  id              String     @id @default(uuid()) @db.Uuid
  workspaceId     String     @map("workspace_id") @db.Uuid
  email           String     @db.VarChar(255)
  role            SystemRole @default(user)
  invitationToken String     @unique @map("invitation_token") @db.VarChar(255)
  invitedByUserId String?    @map("invited_by_user_id") @db.Uuid
  expiresAt       DateTime   @map("expires_at") @db.Timestamptz(6)
  acceptedAt      DateTime?  @map("accepted_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedByUser User?     @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@map("invitations")
}

// =========================================================
// COMPANY PROFILE & SETTINGS
// =========================================================

model Company {
  id                 String   @id @default(uuid()) @db.Uuid
  workspaceId        String   @unique @map("workspace_id") @db.Uuid
  companyName        String   @map("company_name") @db.VarChar(255)
  legalName          String?  @map("legal_name") @db.VarChar(255)
  logoFileId         String?  @map("logo_file_id") @db.Uuid
  email              String?  @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  website            String?  @db.VarChar(255)
  addressLine1       String?  @map("address_line1") @db.VarChar(255)
  addressLine2       String?  @map("address_line2") @db.VarChar(255)
  city               String?  @db.VarChar(150)
  postalCode         String?  @map("postal_code") @db.VarChar(50)
  taxNumber               String?   @map("tax_number") @db.VarChar(100)
  registrationNumber      String?   @map("registration_number") @db.VarChar(100)
  // Compliance profile fields (Slice 8.1)
  jurisdictionId          String?   @map("jurisdiction_id") @db.Uuid
  taxRegistrationNumber   String?   @map("tax_registration_number") @db.VarChar(100)
  vatRegistered           Boolean   @default(false) @map("vat_registered")
  vatRegistrationNumber   String?   @map("vat_registration_number") @db.VarChar(100)
  corporateTaxRegistered  Boolean   @default(false) @map("corporate_tax_registered")
  corporateTaxNumber      String?   @map("corporate_tax_number") @db.VarChar(100)
  tradeLicenseNumber      String?   @map("trade_license_number") @db.VarChar(100)
  tradeLicenseExpiry      DateTime? @map("trade_license_expiry") @db.Date
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logoFile     File?           @relation("CompanyLogo", fields: [logoFileId], references: [id], onDelete: SetNull)
  jurisdiction CountryProfile? @relation("CompanyJurisdiction", fields: [jurisdictionId], references: [id])

  @@map("companies")
}

model CompanySettings {
  id                            String   @id @default(uuid()) @db.Uuid
  workspaceId                   String   @unique @map("workspace_id") @db.Uuid
  invoicePrefix                 String   @default("INV") @map("invoice_prefix") @db.VarChar(20)
  nextInvoiceNumber             Int      @default(1) @map("next_invoice_number")
  defaultInvoiceDueDays         Int      @default(14) @map("default_invoice_due_days")
  defaultTaxRate                Decimal? @default(0) @map("default_tax_rate") @db.Decimal(10, 4)
  reminderLeadDays              Int      @default(3) @map("reminder_lead_days")
  emailNotificationsEnabled     Boolean  @default(true) @map("email_notifications_enabled")
  dashboardNotificationsEnabled Boolean  @default(true) @map("dashboard_notifications_enabled")
  brandColor                    String?  @default("#2563eb") @map("brand_color") @db.VarChar(7)
  nextPaymentNumber             Int      @default(1) @map("next_payment_number")
  paymentPrefix                 String   @default("PAY") @map("payment_prefix") @db.VarChar(20)
  nextExpenseNumber             Int      @default(1) @map("next_expense_number")
  expensePrefix                 String   @default("EXP") @map("expense_prefix") @db.VarChar(20)
  createdAt                     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// =========================================================
// SUBSCRIPTIONS, PLANS & BILLING
// =========================================================

model Plan {
  id                    String               @id @default(uuid()) @db.Uuid
  code                  SubscriptionPlanCode @unique
  name                  String               @db.VarChar(100)
  description           String?              @db.Text
  monthlyPriceUsd       Decimal              @default(0) @map("monthly_price_usd") @db.Decimal(10, 2)
  yearlyPriceUsd        Decimal?             @default(0) @map("yearly_price_usd") @db.Decimal(10, 2)
  displayOrder          Int                  @default(0) @map("display_order")
  isRecommended         Boolean              @default(false) @map("is_recommended")
  isPublic              Boolean              @default(true) @map("is_public")
  includedUsers         Int                  @map("included_users")
  maxUsers              Int?                 @map("max_users")
  maxMonthlyInvoices    Int?                 @map("max_monthly_invoices")
  maxMonthlyAiRequests  Int?                 @map("max_monthly_ai_requests")
  maxStorageMb          Int?                 @map("max_storage_mb")
  hasExpenses           Boolean              @default(false) @map("has_expenses")
  hasAiCategorization   Boolean              @default(false) @map("has_ai_categorization")
  hasAdvancedCompliance Boolean              @default(false) @map("has_advanced_compliance")
  isActive              Boolean              @default(true) @map("is_active")
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  workspaceId          String             @unique @map("workspace_id") @db.Uuid
  planId               String             @map("plan_id") @db.Uuid
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?            @map("stripe_subscription_id") @db.VarChar(255)
  currentPeriodStart   DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan          Plan           @relation(fields: [planId], references: [id])
  billingEvents BillingEvent[]

  @@index([workspaceId])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model BillingEvent {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String?          @map("workspace_id") @db.Uuid
  subscriptionId  String?          @map("subscription_id") @db.Uuid
  eventType       BillingEventType @map("event_type")
  provider        String           @default("stripe") @db.VarChar(50)
  providerEventId String?          @map("provider_event_id") @db.VarChar(255)
  payload         Json?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@map("billing_events")
}

// =========================================================
// FILES
// =========================================================

model File {
  id               String   @id @default(uuid()) @db.Uuid
  workspaceId      String   @map("workspace_id") @db.Uuid
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  storageProvider  String    @default("cloudflare_r2") @map("storage_provider") @db.VarChar(50)
  bucketName       String?   @map("bucket_name") @db.VarChar(255)
  objectKey        String    @map("object_key") @db.Text
  originalFilename String?   @map("original_filename") @db.VarChar(255)
  fileName         String?   @map("file_name") @db.VarChar(255)
  mimeType         String?   @map("mime_type") @db.VarChar(100)
  fileSizeBytes    BigInt?   @map("file_size_bytes")
  description      String?   @db.Text
  publicUrl        String?   @map("public_url") @db.Text
  isDeleted        Boolean   @default(false) @map("is_deleted")
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedByUserId  String?   @map("deleted_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
