# ============================================================
# Tetri Copilot Backend — Environment Variables
# Copy to .env and fill in values for your environment
# ============================================================

# Application
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tetri_copilot_db

# CORS — comma-separated origins allowed to call this API
CORS_ORIGIN=http://localhost:5173

# ============================================================
# URLs (Slice 10.5 — App Boundary)
# ============================================================
APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
WEBSITE_URL=http://localhost:5175
API_URL=http://localhost:5000

# ============================================================
# Authentication (Clerk)
# Get from: https://dashboard.clerk.com → your app → API Keys
# ============================================================
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# File Storage (Cloudflare R2)
# Optional — falls back to local filesystem if not set
# ============================================================
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=tetri-copilot-files
# R2_PUBLIC_URL=

# ============================================================
# Email (Resend)
# Optional — emails are no-ops without this
# ============================================================
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@tetricopilot.com

# ============================================================
# AI (OpenAI)
# Optional — AI features disabled without this
# ============================================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Billing (Stripe)
# Optional — billing features disabled without this
# ============================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Admin Panel (Slice 19.1 — standalone JWT, no Clerk)
# Generate: openssl rand -hex 32
# ============================================================
ADMIN_JWT_SECRET=change-me-in-production

# ============================================================
# Deployment (Slice 13.1)
# Required for CI/CD automated deployment logging
# Generate: openssl rand -hex 32
# ============================================================
# DEPLOY_SECRET=

# ============================================================
# Observability (Slice 13.3)
# ============================================================
# SENTRY_DSN=
