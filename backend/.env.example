# ============================================================
# Tetri Copilot Backend — Environment Variables
# Copy this file to .env and fill in values for your environment
# ============================================================

# Application
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tetri_copilot_db

# CORS — frontend origin allowed to call this API
CORS_ORIGIN=http://localhost:5173

# ============================================================
# Sprint 1 — Authentication (Clerk)
# ============================================================
# CLERK_SECRET_KEY=sk_test_...
# CLERK_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# Sprint 5 — File Storage (Cloudflare R2)
# ============================================================
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=tetri-copilot-files
# R2_PUBLIC_URL=

# ============================================================
# Sprint 6 — Email (Resend)
# ============================================================
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ============================================================
# Sprint 7 — AI (OpenAI)
# ============================================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Sprint 8 — Billing (Stripe)
# ============================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================================
# Monitoring (Sentry) — add when deploying to production
# ============================================================
# SENTRY_DSN=
