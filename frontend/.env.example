# ============================================================
# Tetri Copilot Frontend — Environment Variables
# Copy to .env and fill in values for your environment
# ============================================================

# Backend API base URL
# Development: http://localhost:5000
# Production:  https://api.tetricopilot.com
VITE_API_BASE_URL=http://localhost:5000

# Clerk publishable key
# Get from: https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Environment label (shown in System Status page)
VITE_ENVIRONMENT=development

# ============================================================
# App Boundary URLs (Slice 10.5)
# ============================================================
VITE_APP_URL=http://localhost:5173
VITE_ADMIN_URL=http://localhost:5174
VITE_WEBSITE_URL=http://localhost:5175
